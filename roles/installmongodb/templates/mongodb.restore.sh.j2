#!/bin/bash

# Remove current MongoDB backup directory contents
if [ -n "$(ls -A /{{ prop_basename}}/mongodb/backup)" ]; then
    rm -r -f /{{ prop_basename}}/mongodb/data/backup/*
fi

# Restore latest backup of MongoDB backup directory
if [ -n "$(ls -A /mnt/data-{{ prop_environment }}/mongodb/{{ prop_hostname }}/backup)" ]; then
    ls -tr /mnt/data-{{ prop_environment }}/mongodb/{{ prop_hostname }}/backup | tail -n 1 | xargs -I {} unzip -o /mnt/data-{{ prop_environment }}/mongodb/{{ prop_hostname }}/backup/{} -d /
fi
